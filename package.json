{
  "name": "st-storyecho",
  "version": "0.12.0",
  "private": true,
  "type": "module",
  "description": "Sliding-window context and story-memory recall for SillyTavern.",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --format=esm --target=es2022 --outfile=dist/index.js --sourcemap",
    "dev": "npm run build -- --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "npm run typecheck && npm run build && npm run test"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
