{
  "name": "st-storyecho",
  "version": "0.20.23",
  "private": true,
  "type": "module",
  "description": "Sliding-window context and story-memory recall for SillyTavern.",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --format=esm --target=es2022 --outfile=dist/index.js --sourcemap",
    "dev": "npm run build -- --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "audit:dependencies": "npm audit --audit-level=high",
    "check": "npm run typecheck && npm run build && npm run test:coverage"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "3.2.7",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
